NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kalingalink

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false

# CORS
CLIENT_ORIGIN=http://localhost:5173

# Email (optional in dev)
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=KalingaLink <no-reply@kalingalink.local>

# Chatbot — get a FREE Groq key at https://console.groq.com/keys (no credit card)
# Or use Gemini at https://aistudio.google.com/app/apikey
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CHAT_PROVIDER=groq
